<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="${mainApplicationId}.permission.IPC" />

    <!-- Required by taskerpluginlibrary to start its bound query service in the background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Required to show foreground service notification on Android 13+ (targetSdk >= 33) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Package visibility (Android 11+):
      * The fcitx5 main app entry MUST be present so bindFcitxRemoteService() can
        resolve the IPC service. Without it, AGP's manifest merger silently drops
        plugin-base's contribution because we declared a <queries> block ourselves
        (a sibling <queries> at higher priority replaces, not merges, the lower one).
      * The Tasker entries let requestQuery()'s queryBroadcastReceivers/Services find
        Tasker (and binary-compatible forks/legacy installs).
    -->
    <queries>
        <package android:name="${mainApplicationId}" />
        <package android:name="net.dinglisch.android.taskerm" />
        <!--
          Real action used by Tasker's REQUEST_QUERY receivers (and locale forks).
          The constant is com.twofortyfouram.locale.intent.action.REQUEST_QUERY,
          NOT net.dinglisch.android.tasker.ACTION_REQUEST_QUERY.
        -->
        <intent>
            <action android:name="com.twofortyfouram.locale.intent.action.REQUEST_QUERY" />
        </intent>
    </queries>

    <application
        android:icon="@mipmap/ic_launcher_plugin_generic"
        android:label="@string/app_name">

        <service
            android:name=".MainService"
            android:directBootAware="true"
            android:exported="true"
            android:permission="${mainApplicationId}.permission.PLUGIN"
            tools:targetApi="24">
            <intent-filter>
                <action android:name="${mainApplicationId}.plugin.SERVICE" />
            </intent-filter>
        </service>

        <activity
            android:name=".ClipboardChangedConfigActivity"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_plugin_generic"
            android:label="@string/tasker_event_label">
            <intent-filter>
                <action android:name="net.dinglisch.android.tasker.ACTION_EDIT_EVENT" />
            </intent-filter>
        </activity>
    </application>
</manifest>
